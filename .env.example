# VPMA Environment Variables (ROOT — reference only)
# The backend loads .env from backend/.env, NOT from the project root.
# Use backend/.env.example instead:
#   cd backend && cp .env.example .env

# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Optional: Ollama (Phase 2+ — local LLM, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
